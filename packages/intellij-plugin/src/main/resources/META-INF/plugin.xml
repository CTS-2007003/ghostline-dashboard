<idea-plugin>
  <id>com.ghostline</id>
  <name>Ghostline — AI Line Tracker</name>
  <version>0.1.0</version>
  <vendor>Ghostline</vendor>
  <description>Tracks AI-generated vs human-written lines and reports to your team dashboard.</description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService
      serviceInterface="com.ghostline.AuthManager"
      serviceImplementation="com.ghostline.AuthManager"/>
    <applicationService
      serviceInterface="com.ghostline.SessionStore"
      serviceImplementation="com.ghostline.SessionStore"/>
    <applicationService
      serviceInterface="com.ghostline.GhostlineSettings"
      serviceImplementation="com.ghostline.GhostlineSettings"/>
    <applicationConfigurable
      instance="com.ghostline.GhostlineConfigurable"
      displayName="Ghostline"/>
  </extensions>

  <applicationListeners>
    <listener
      class="com.ghostline.AppLifecycleHandler"
      topic="com.intellij.ide.AppLifecycleListener"/>
  </applicationListeners>

  <projectListeners>
    <listener
      class="com.ghostline.DocumentTracker"
      topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    <listener
      class="com.ghostline.ProjectOpenListener"
      topic="com.intellij.openapi.project.ProjectManagerListener"/>
  </projectListeners>

  <extensions defaultExtensionNs="com.intellij">
    <notificationGroup
      id="Ghostline"
      displayType="BALLOON"
      isLogByDefault="false"/>
  </extensions>

  <actions>
    <group id="com.ghostline.MenuGroup" text="Ghostline" popup="true">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <action id="com.ghostline.Activate"
              class="com.ghostline.GhostlineActivateAction"
              text="Activate / Setup"
              description="Activate Ghostline and run setup if needed"/>
      <action id="com.ghostline.TogglePause"
              class="com.ghostline.GhostlineTogglePauseAction"
              text="Pause Tracking"
              description="Pause or resume line count tracking"/>
      <action id="com.ghostline.ResetSession"
              class="com.ghostline.GhostlineResetSessionAction"
              text="Reset Session"
              description="Discard unsaved line count for this session"/>
      <action id="com.ghostline.FlushNow"
              class="com.ghostline.GhostlineFlushNowAction"
              text="Flush Now"
              description="Push current line counts to GitHub immediately"/>
    </group>
  </actions>
</idea-plugin>
