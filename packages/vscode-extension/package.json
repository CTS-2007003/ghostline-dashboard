{
  "name": "ghostline",
  "displayName": "Ghostline — AI Line Tracker",
  "description": "Tracks AI-generated vs human-written lines and reports to your team dashboard.",
  "version": "0.1.0",
  "publisher": "ghostline",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["*"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghostline.setToken",
        "title": "Ghostline: Set GitHub Token"
      },
      {
        "command": "ghostline.showStatus",
        "title": "Ghostline: Show Status"
      },
      {
        "command": "ghostline.activate",
        "title": "Ghostline: Activate"
      },
      {
        "command": "ghostline.togglePause",
        "title": "Ghostline: Pause / Resume Tracking"
      },
      {
        "command": "ghostline.resetSession",
        "title": "Ghostline: Reset Session"
      },
      {
        "command": "ghostline.flushNow",
        "title": "Ghostline: Flush Now"
      }
    ],
    "configuration": {
      "title": "Ghostline",
      "properties": {
        "ghostline.githubRepo": {
          "type": "string",
          "default": "",
          "description": "Central dashboard repo in owner/repo format (e.g. myorg/ghostline-dashboard)"
        },
        "ghostline.githubUsername": {
          "type": "string",
          "default": "",
          "description": "Your GitHub username"
        },
        "ghostline.displayName": {
          "type": "string",
          "default": "",
          "description": "Your display name shown on the team dashboard (e.g. your real name or nickname)"
        },
        "ghostline.team": {
          "type": "string",
          "default": "",
          "description": "Your team name (e.g. Frontend, Backend, Mobile)"
        },
        "ghostline.flushIntervalMinutes": {
          "type": "number",
          "default": 5,
          "description": "How often to flush counts to GitHub (minutes)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
